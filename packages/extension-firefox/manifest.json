{
  "manifest_version": 3,
  "name": "gitmarks",
  "version": "0.0.1",
  "description": "Save bookmarks to your own GitHub repo.",
  "permissions": ["storage", "activeTab", "bookmarks", "alarms"],
  "host_permissions": ["https://api.github.com/*"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "gitmarks",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https://api.github.com"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "gitmarks@paperhurts.dev",
      "strict_min_version": "121.0"
    }
  }
}
