# Credentials for the real-GitHub round-trip e2e (reconcile-roundtrip.spec.ts).
# Copy to .env.e2e (gitignored) and fill in. Without these, that test skips.
# Use a THROWAWAY private repo and a fine-grained PAT scoped to ONLY that repo
# with Contents: read/write. Revoke it when you're done.
GITMARKS_E2E_TOKEN=github_pat_xxx
GITMARKS_E2E_OWNER=your-github-login
GITMARKS_E2E_REPO=gitmarks-e2e
